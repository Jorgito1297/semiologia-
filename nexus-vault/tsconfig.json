{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@nexusvault/types/*": ["./packages/types/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "apps/*/node_modules",
    "apps/*/dist",
    "packages/*/node_modules",
    "packages/*/dist"
  ]
}
