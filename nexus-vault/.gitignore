# =============================================================================
# NEXUS VAULT — .gitignore
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
.nuxt/
.output/
*.tsbuildinfo

# ── Environment files — NEVER commit these ───────────────────────────────────
.env
.env.*
!.env.example          # keep the example template
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging

# ── Firebase service account keys ────────────────────────────────────────────
serviceAccount*.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
# Catch-all for any JSON in root that looks like a service account
google-services.json
GoogleService-Info.plist

# ── TLS certificates ─────────────────────────────────────────────────────────
infrastructure/nginx/certs/*.pem
infrastructure/nginx/certs/*.crt
infrastructure/nginx/certs/*.key
infrastructure/nginx/certs/*.p12
infrastructure/nginx/certs/*.pfx
!infrastructure/nginx/certs/.gitkeep

# ── Prisma ───────────────────────────────────────────────────────────────────
# Track migrations in version control (do NOT gitignore migrations/)
# But ignore the generated client
node_modules/.prisma/

# ── Docker ───────────────────────────────────────────────────────────────────
# Volume data dirs (if mounted locally in dev)
.docker/
docker-volumes/
postgres-data/
minio-data/
redis-data/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log.*

# ── Testing & Coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
.pytest_cache/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
!.vscode/extensions.json    # keep recommended extensions list
.idea/
*.swp
*.swo
*.suo
*.user
*.iml
*.sublime-workspace

# ── TypeScript ───────────────────────────────────────────────────────────────
*.js.map
*.d.ts.map

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
.temp/
tmp/
*.tmp
*.bak
*.orig
.husky/_/
