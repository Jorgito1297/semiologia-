# Local-first LLM configuration (no paid credits)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=60

# Embeddings pipeline provider: ollama | openai | offline
EMBEDDING_PROVIDER=ollama

# Optional cloud providers (leave empty to avoid external spending)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Project settings (fill with your values when needed)
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private metrics dashboard (GET /api/private-metrics?key=...)
# METRICS_ADMIN_KEY = full read+write access (keep secret, admin only)
METRICS_ADMIN_KEY=
# METRICS_WRITE_KEY = write-only access for the Next.js server-to-server calls
METRICS_WRITE_KEY=
# NEXT_PUBLIC_METRICS_WRITE_KEY = same value as METRICS_WRITE_KEY, exposed to the browser client
# Set this so trackPrivateMetric() can authenticate POST requests in production
NEXT_PUBLIC_METRICS_WRITE_KEY=

# Moodle integration (Python downloader and Supabase proxy)
MOODLE_URL=https://moodle.uce.edu.do
MOODLE_USERNAME=
MOODLE_PASSWORD=
MOODLE_TOKEN=

# Teams local ingestion (Guardian watcher)
LOCAL_TEAMS_PATH=
