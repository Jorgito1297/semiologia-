# =============================================================================
# .env.production — Variables de entorno para el servidor Hostinger VPS
# Colocar en: /var/www/semiologia/.env
# NUNCA subir este archivo a Git (está en .gitignore)
# =============================================================================

# Node
NODE_ENV=production
PORT=3000

# ---
# Supabase (ya configurado en el proyecto local)
# ---
NEXT_PUBLIC_SUPABASE_URL=https://fnusnboleqnabqwqfucr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://fnusnboleqnabqwqfucr.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---
# LLM para generación de preguntas (question-bank API)
# Elige uno: Gemini (gratis) o OpenAI
# ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=          # <-- PEGAR TU KEY AQUI si usas Gemini
# OPENAI_API_KEY=        # <-- O usar OpenAI

# En producción no hay Ollama — deshabilitar
# LLM_PROVIDER=ollama

# ---
# Métricas privadas
# ---
METRICS_ADMIN_KEY=       # <-- Generar: openssl rand -hex 32
METRICS_WRITE_KEY=       # <-- Puede ser el mismo valor o diferente
NEXT_PUBLIC_METRICS_WRITE_KEY=  # <-- Igual que METRICS_WRITE_KEY

# ---
# (Opcional) Embeddings — no necesario en producción si el banco está pre-generado
# ---
EMBEDDING_PROVIDER=offline
